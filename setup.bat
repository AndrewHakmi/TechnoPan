@echo off
:: ============================================================
::  TechnoPan — установка и проверка зависимостей
::  Двойной клик — всё остальное скрипт сделает сам
:: ============================================================
title TechnoPan — Установка

powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0setup.ps1"

if errorlevel 1 (
    echo.
    echo [ОШИБКА] Установка завершилась с ошибкой. Смотрите сообщения выше.
    pause
    exit /b 1
)

pause
